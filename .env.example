# Claude API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Logging Configuration (optional)
# Enable verbose logging to see detailed SDK and API interactions in the terminal
# AGENT_VERBOSE=true

# Enable debug logging for full trace-level logging including API request/response details
# AGENT_DEBUG=true

# When verbose/debug mode is enabled, you'll see:
# - 📤 API requests to Claude
# - 📥 API responses
# - 🚀 Subagent spawning and lifecycle
# - 🔧 Tool calls with parameters
# - ✅ Tool results and success/failure status
# - 📝 Agent context and model information
